{
  "name": "@a3-electron-template/desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev:bundle": "tsc -p tsconfig.json -w",
    "dev:electron": "bun run scripts/dev-electron.mjs",
    "dev": "bun run --parallel dev:bundle dev:electron",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "start": "electron ."
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "electron": "^41.0.2",
    "typescript": "catalog:",
    "wait-on": "^9.0.4"
  }
}
