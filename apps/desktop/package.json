{
  "name": "@a3-electron-template/desktop",
  "version": "0.0.0",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev:bundle": "tsdown --watch",
    "dev:electron": "bun run scripts/dev-electron.mjs",
    "dev": "bun run --parallel dev:bundle dev:electron",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "start": "electron .",
    "dist": "tsdown && electron-builder"
  },
  "dependencies": {
    "@a3-electron-template/contracts": "workspace:*",
    "electron-updater": "^6.8.3",
    "electron-window-state": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "tsdown": "^0.21.4",
    "typescript": "catalog:",
    "wait-on": "^9.0.4"
  }
}
