{
  "name": "@a3-electron-template/monorepo",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "typescript": "5.9.2",
      "@types/bun": "^1.3.9",
      "@types/node": "^24.10.13"
    }
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "oxlint --report-unused-disable-directives",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "check-types": "turbo run typecheck",
    "serve:updates": "bunx serve release --listen 3001",
    "dist": "bun run build && bun run --cwd apps/desktop dist"
  },
  "devDependencies": {
    "eslint-plugin-turbo": "^2.8.17",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "turbo": "^2.8.17"
  },
  "engines": {
    "bun": "^1.3.10",
    "node": "^24.13.1"
  },
  "packageManager": "bun@1.3.10"
}
